# Google OAuth configuration for Streamlit
# Copy this file to secrets.toml and fill in your values.
#
# Setup instructions:
# 1. Go to https://console.cloud.google.com/
# 2. Create a project (or use existing)
# 3. Enable the "Google Drive API" (APIs & Services > Library)
# 4. Configure OAuth consent screen (APIs & Services > OAuth consent screen)
#    - App type: Internal (for company use) or External
#    - Add scope: https://www.googleapis.com/auth/drive.readonly
# 5. Create OAuth 2.0 Client ID (APIs & Services > Credentials > Create Credentials)
#    - Application type: Web application
#    - Authorized redirect URIs:
#        Local:    http://localhost:8501/oauth2callback
#        Deployed: https://your-app.streamlit.app/oauth2callback
# 6. Copy client_id and client_secret below

# =============================================================================
# Google Picker API (optional - for file picker popup)
# =============================================================================
# IMPORTANT: This key MUST be placed BEFORE any [section] headers.
# In TOML, keys after a [section] header belong to that section, not top-level.
#
# To enable Google Drive file picker popup:
# 1. Enable "Google Picker API" in Google Cloud Console (APIs & Services > Library)
# 2. Create an API Key (APIs & Services > Credentials > Create Credentials > API Key)
# 3. Add your API origin to the key's restrictions (HTTP referrers)
# 4. Copy the API key below

api_key = "YOUR_GOOGLE_API_KEY_HERE"

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "CHANGE_ME_random_string_at_least_32_chars_long"
client_id = "YOUR_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
expose_tokens = ["id", "access"]

[auth.client_kwargs]
scope = "openid profile email https://www.googleapis.com/auth/drive.readonly"
